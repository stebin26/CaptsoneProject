# ============================================================
# Operations Intelligence Platform — environment template
# Copy to .env and adjust as needed:  cp .env.example .env
# ============================================================

# ---- Environment ----
OPS_ENVIRONMENT=development
OPS_DEBUG=true
OPS_LOG_LEVEL=INFO

# ---- Postgres (the hub) ----
OPS_POSTGRES_HOST=postgres
OPS_POSTGRES_PORT=5432
OPS_POSTGRES_DB=ops
OPS_POSTGRES_USER=ops
OPS_POSTGRES_PASSWORD=ops

# ---- DuckDB (analytics) ----
OPS_DUCKDB_PATH=/data/analytics.duckdb

# ---- Paths ----
OPS_UPLOAD_DIR=/data/uploads

# ---- API gateway ----
OPS_API_HOST=0.0.0.0
OPS_API_PORT=8000
OPS_API_CORS_ORIGINS=["http://localhost:8050"]

# ---- Dashboard ----
OPS_API_BASE_URL=http://api:8000/api/v1
OPS_DASH_HOST=0.0.0.0
OPS_DASH_PORT=8050

# ---- LLM (mapping suggester) ----
# Set OPS_LLM_ENABLED=false to run fully offline on the keyword fallback
# (required for data that cannot be sent to a cloud LLM, e.g. MIMIC).
OPS_LLM_ENABLED=true
OPS_LLM_MODEL=claude-sonnet-4-6
OPS_ANTHROPIC_API_KEY=AIRFLOW_FERNET_KEY=
AIRFLOW_API_SECRET_KEY=
AIRFLOW_JWT_SECRET=
AIRFLOW_FERNET_KEY=JUbKF1nkG4rKnj4sBLDsuSx8w4agDMQXItY17pYrPsI=
AIRFLOW_API_SECRET_KEY=75efbadc70929e24baf6deccc12974732df909630bfc7f708ce8ae3cefbed82c
AIRFLOW_JWT_SECRET=628cbe7cb8406dcc4aaad9b714b9ddb6d8cf265590319be133eb4c6f5f81866c
