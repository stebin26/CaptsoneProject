# ============================================================
# Operations Intelligence Platform — environment template
# Copy to .env and adjust as needed:  cp .env.example .env
# ============================================================

# ---- Environment ----
OPS_ENVIRONMENT=development
OPS_DEBUG=true
OPS_LOG_LEVEL=INFO

# ---- Postgres (the hub) ----
OPS_POSTGRES_HOST=postgres
OPS_POSTGRES_PORT=5432
OPS_POSTGRES_DB=ops
OPS_POSTGRES_USER=ops
OPS_POSTGRES_PASSWORD=ops

# ---- DuckDB (analytics) ----
OPS_DUCKDB_PATH=/data/analytics.duckdb

# ---- Paths ----
OPS_UPLOAD_DIR=/data/uploads

# ---- API gateway ----
OPS_API_HOST=0.0.0.0
OPS_API_PORT=8000
OPS_API_CORS_ORIGINS=["http://localhost:8050"]

# ---- Dashboard ----
OPS_API_BASE_URL=http://api:8000/api/v1
OPS_DASH_HOST=0.0.0.0
OPS_DASH_PORT=8050

# ---- LLM (mapping suggester) ----
# ---- LLM (mapping suggester + RAG) ----
OPS_LLM_ENABLED=true
OPS_LLM_PROVIDER=ollama
OPS_OLLAMA_URL=http://host.docker.internal:11434
OPS_OLLAMA_MODEL=llama3.2:3b
OPS_INTELLIGENCE_LLM_POLISH=false

OPS_AGENT_MODEL=llama3.2:3b
OPS_AGENT_NUM_CTX=4096
OPS_AGENT_LLM_TIMEOUT=180
# ---- Airflow secrets ----
AIRFLOW_FERNET_KEY=JUbKF1nkG4rKnj4sBLDsuSx8w4agDMQXItY17pYrPsI=
